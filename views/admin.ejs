<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>National Admin Matrix 2.0</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;700;900&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <style>
        :root {
            --saffron: #FF9933;
            --saffron-light: rgba(255, 153, 51, 0.12);
            --green: #138808;
            --ink: #0f172a;
            --ink2: #1e293b;
            --surface: #ffffff;
            --surface2: #f8fafc;
            --border: #e2e8f0;
            --muted: #94a3b8;
            --red: #dc2626;
            --blue: #2563eb;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: #f1f5f9;
            color: var(--ink);
            min-height: 100vh;
        }

        /* ── TOPBAR ── */
        .topbar {
            background: var(--ink);
            border-bottom: 4px solid var(--saffron);
            padding: 0 2rem;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .topbar-brand {
            display: flex;
            align-items: baseline;
            gap: 0.5rem;
        }

        .topbar-brand h1 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.7rem;
            letter-spacing: 0.08em;
            color: #fff;
            line-height: 1;
        }

        .topbar-brand h1 span {
            color: var(--saffron);
        }

        .topbar-brand p {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--muted);
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .badge-pulse {
            background: var(--saffron);
            color: #fff;
            font-size: 0.55rem;
            font-weight: 900;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            padding: 0.35rem 0.75rem;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.6;
            }
        }

        .btn-logout {
            background: var(--red);
            color: #fff;
            font-size: 0.6rem;
            font-weight: 900;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            padding: 0.4rem 1rem;
            border: none;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            transition: opacity 0.2s;
        }

        .btn-logout:hover {
            opacity: 0.85;
        }

        /* ── LAYOUT ── */
        .page {
            padding: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* ── KPI ROW ── */
        .kpi-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.25rem;
            margin-bottom: 1.5rem;
        }

        .kpi-card {
            background: var(--surface);
            border-top: 4px solid var(--border);
            padding: 1.5rem 1.75rem;
            position: relative;
            overflow: hidden;
        }

        .kpi-card.saffron {
            border-top-color: var(--saffron);
        }

        .kpi-card.green {
            border-top-color: var(--green);
        }

        .kpi-card.ink {
            border-top-color: var(--ink);
        }

        .kpi-label {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 0.5rem;
        }

        .kpi-value {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 3.5rem;
            line-height: 1;
        }

        .kpi-value.saffron {
            color: var(--saffron);
        }

        .kpi-value.green {
            color: var(--green);
        }

        .kpi-value.ink {
            color: var(--ink);
        }

        .kpi-sub {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #cbd5e1;
            margin-top: 0.75rem;
        }

        .status-dot-row {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            margin-top: 0.25rem;
        }

        .dot-ping {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #22c55e;
            position: relative;
            flex-shrink: 0;
        }

        .dot-ping::after {
            content: '';
            position: absolute;
            inset: -3px;
            border-radius: 50%;
            background: rgba(34, 197, 94, 0.3);
            animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
        }

        @keyframes ping {
            0% {
                transform: scale(1);
                opacity: 1;
            }

            100% {
                transform: scale(2.5);
                opacity: 0;
            }
        }

        .sync-label {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.3rem;
            letter-spacing: 0.06em;
            color: var(--ink);
        }

        /* ── MAIN GRID ── */
        .main-grid {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 1.25rem;
            margin-bottom: 1.5rem;
        }

        /* ── CHART CARD ── */
        .chart-card {
            background: var(--surface);
            padding: 1.75rem;
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .chart-title {
            font-size: 0.6rem;
            font-weight: 900;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--muted);
        }

        .live-badge {
            font-size: 0.55rem;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--saffron);
            border: 1px solid rgba(255, 153, 51, 0.35);
            background: rgba(255, 153, 51, 0.06);
            padding: 0.25rem 0.6rem;
        }

        .chart-wrap {
            position: relative;
            width: 100%;
        }

        .chart-wrap.line {
            height: 240px;
        }

        .chart-wrap.donut {
            height: 220px;
        }

        /* ── BOTTOM GRID ── */
        .bottom-grid {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 1.25rem;
        }

        /* ── TABLE CARD ── */
        .table-card {
            background: var(--surface);
            overflow: hidden;
        }

        .table-head-bar {
            background: var(--ink);
            padding: 1.1rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 4px solid var(--saffron);
        }

        .table-head-bar h2 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.3rem;
            letter-spacing: 0.08em;
            color: #fff;
        }

        .access-badge {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--green);
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .access-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--green);
            display: inline-block;
        }

        .tbl {
            width: 100%;
            border-collapse: collapse;
        }

        .tbl thead tr {
            background: var(--surface2);
        }

        .tbl th {
            font-size: 0.58rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--muted);
            padding: 0.85rem 1.25rem;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .tbl th:last-child {
            text-align: right;
        }

        .report-row {
            cursor: pointer;
            border-bottom: 1px solid var(--border);
            transition: background 0.15s;
        }

        .report-row:hover {
            background: #fafafa;
        }

        .tbl td {
            padding: 0.85rem 1.25rem;
            vertical-align: middle;
            font-size: 0.82rem;
            color: #475569;
            font-weight: 500;
        }

        .td-id {
            font-size: 0.6rem;
            font-weight: 900;
            color: #cbd5e1;
            font-family: 'DM Sans', monospace;
            letter-spacing: 0.05em;
        }

        .source-name {
            font-weight: 700;
            color: var(--ink);
            display: block;
            font-size: 0.82rem;
        }

        .source-phone {
            font-size: 0.62rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--muted);
        }

        .anon-tag {
            font-size: 0.62rem;
            font-weight: 900;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--muted);
        }

        .snippet {
            max-width: 220px;
            font-size: 0.78rem;
            line-height: 1.5;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }

        .status-pill {
            display: inline-block;
            padding: 0.25rem 0.6rem;
            font-size: 0.58rem;
            font-weight: 900;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            border: 2px solid;
        }

        .status-pill.pending {
            border-color: #94a3b8;
            color: #94a3b8;
        }

        .status-pill.investigating {
            border-color: var(--blue);
            color: var(--blue);
        }

        .status-pill.resolved {
            border-color: var(--green);
            color: var(--green);
        }

        .status-pill.dismissed {
            border-color: var(--red);
            color: var(--red);
        }

        .eye-btn {
            width: 32px;
            height: 32px;
            background: var(--surface2);
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            color: var(--muted);
            transition: background 0.15s, color 0.15s;
        }

        .eye-btn:hover {
            background: var(--saffron);
            color: #fff;
        }

        .tbl td:last-child {
            text-align: right;
        }

        /* ── MODAL ── */
        .modal-overlay {
            position: fixed;
            inset: 0;
            z-index: 300;
            display: none;
        }

        .modal-overlay.open {
            display: block;
        }

        .modal-backdrop {
            position: absolute;
            inset: 0;
            background: rgba(15, 23, 42, 0.88);
            backdrop-filter: blur(6px);
            cursor: pointer;
        }

        .modal-box {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: min(680px, calc(100vw - 2rem));
            background: var(--surface);
            border-top: 8px solid var(--saffron);
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.4);
            padding: 2.5rem;
            animation: modalIn 0.25s ease;
        }

        @keyframes modalIn {
            from {
                opacity: 0;
                transform: translate(-50%, -52%) scale(0.97);
            }

            to {
                opacity: 1;
                transform: translate(-50%, -50%) scale(1);
            }
        }

        .modal-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 2rem;
        }

        .modal-id {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.2rem;
            letter-spacing: 0.06em;
            color: var(--ink);
            line-height: 1;
        }

        .modal-source-label {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--muted);
            margin-top: 0.3rem;
        }

        .modal-close-btn {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--surface2);
            border: none;
            cursor: pointer;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
            flex-shrink: 0;
            transition: background 0.15s, color 0.15s;
        }

        .modal-close-btn:hover {
            background: #fee2e2;
            color: var(--red);
        }

        .modal-content-label {
            font-size: 0.6rem;
            font-weight: 900;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #cbd5e1;
            margin-bottom: 0.6rem;
        }

        .modal-content-box {
            padding: 1.25rem 1.5rem;
            background: var(--surface2);
            border-left: 4px solid var(--saffron);
            font-size: 0.88rem;
            font-weight: 500;
            font-style: italic;
            line-height: 1.7;
            color: #475569;
            margin-bottom: 2rem;
        }

        .modal-form-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.25rem;
            margin-bottom: 1.5rem;
        }

        .form-field label {
            display: block;
            font-size: 0.6rem;
            font-weight: 900;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #cbd5e1;
            margin-bottom: 0.5rem;
        }

        .form-field select {
            width: 100%;
            border: none;
            border-bottom: 2px solid var(--border);
            padding: 0.5rem 0;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.75rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--ink);
            background: transparent;
            outline: none;
            cursor: pointer;
            transition: border-color 0.2s;
        }

        .form-field select:focus {
            border-bottom-color: var(--saffron);
        }

        .modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
        }

        .btn-submit {
            background: var(--ink);
            color: #fff;
            border: none;
            padding: 0.75rem 2.5rem;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.6rem;
            font-weight: 900;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.2s, transform 0.1s;
        }

        .btn-submit:hover {
            background: #1e293b;
        }

        .btn-submit:active {
            transform: scale(0.98);
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .modal-msg {
            margin-top: 1rem;
            text-align: center;
            font-size: 0.6rem;
            font-weight: 900;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            min-height: 1.2em;
        }

        .modal-msg.success {
            color: var(--green);
        }

        .modal-msg.error {
            color: var(--red);
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 900px) {
            .kpi-row {
                grid-template-columns: 1fr 1fr;
            }

            .main-grid {
                grid-template-columns: 1fr;
            }

            .bottom-grid {
                grid-template-columns: 1fr;
            }

            .kpi-card:nth-child(3) {
                grid-column: span 2;
            }
        }

        @media (max-width: 600px) {
            .kpi-row {
                grid-template-columns: 1fr;
            }

            .kpi-card:nth-child(3) {
                grid-column: span 1;
            }

            .topbar {
                padding: 0 1rem;
            }

            .page {
                padding: 1rem;
            }

            .tbl th,
            .tbl td {
                padding: 0.65rem 0.75rem;
            }

            .snippet {
                max-width: 120px;
            }
        }

        /* ── scrollbar ── */
        ::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 3px;
        }
    </style>
</head>

<body>

    <!-- ── TOPBAR ── -->
    <header class="topbar">
        <div class="topbar-brand">
            <div>
                <h1>National Admin Matrix <span>2.0</span></h1>
                <p>Strategic Intelligence Division &nbsp;|&nbsp; <span id="userName">Loading...</span></p>
            </div>
        </div>
        <div class="topbar-right">
            <div class="badge-pulse">Master View Active</div>
            <a href="/auth/logout" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
        </div>
    </header>

    <!-- ── PAGE ── -->
    <main class="page">

        <!-- KPI Row -->
        <div class="kpi-row">
            <div class="kpi-card saffron">
                <div class="kpi-label">Total Intelligence</div>
                <div class="kpi-value saffron" id="kpiTotal">—</div>
                <div class="kpi-sub">Recorded Signals</div>
            </div>
            <div class="kpi-card green">
                <div class="kpi-label">Unique Reporters</div>
                <div class="kpi-value green" id="kpiReporters">—</div>
                <div class="kpi-sub">Active Sources</div>
            </div>
            <div class="kpi-card ink">
                <div class="kpi-label">System Health</div>
                <div class="status-dot-row" style="margin-top:0.5rem">
                    <div class="dot-ping"></div>
                    <span class="sync-label">Synchronized</span>
                </div>
                <div class="kpi-sub" style="margin-top:0.9rem" id="kpiLastSync">—</div>
            </div>
        </div>

        <!-- Main Grid: Line chart + Donut -->
        <div class="main-grid">

            <!-- Line Chart -->
            <div class="chart-card" style="grid-column: 1 / -1;">
                <div class="chart-header">
                    <span class="chart-title">7-Day Signal Intensity</span>
                    <span class="live-badge">Live Feed</span>
                </div>
                <div class="chart-wrap line">
                    <canvas id="signalsChart"></canvas>
                </div>
            </div>

        </div>

        <!-- Bottom Grid: Donut + Table -->
        <div class="bottom-grid">

            <!-- Donut Chart -->
            <div class="chart-card">
                <div class="chart-header">
                    <span class="chart-title">Mandate Distribution</span>
                </div>
                <div class="chart-wrap donut" style="display:flex;align-items:center;justify-content:center;">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>

            <!-- Table -->
            <div class="table-card">
                <div class="table-head-bar">
                    <h2>Intelligence Stream</h2>
                    <span class="access-badge">Full Access Granted</span>
                </div>
                <div style="overflow-x:auto; max-height: 400px; overflow-y:auto;">
                    <table class="tbl">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Source</th>
                                <th>Content Snippet</th>
                                <th>Mandate</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="reportsTbody">
                            <tr>
                                <td colspan="5"
                                    style="text-align:center;padding:2rem;color:var(--muted);font-size:0.8rem;">Loading
                                    intelligence stream…</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

    <!-- ── MODAL ── -->
    <div id="interventionModal" class="modal-overlay">
        <div class="modal-backdrop" id="modalBackdrop"></div>
        <div class="modal-box">
            <div class="modal-top">
                <div>
                    <div class="modal-id" id="modalIdDisplay"></div>
                    <div class="modal-source-label" id="modalSource"></div>
                </div>
                <button class="modal-close-btn" id="modalCloseBtn"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <div class="modal-content-label">Signal Content</div>
            <div class="modal-content-box" id="modalIssue"></div>

            <form id="statusForm">
                <input type="hidden" id="modalReportId" />
                <div class="modal-form-grid">
                    <div class="form-field">
                        <label>Action Mandate</label>
                        <select id="modalStatus" name="status">
                            <option value="Pending">Pending Analysis</option>
                            <option value="Investigating">Active Investigation</option>
                            <option value="Resolved">Threat Resolved</option>
                            <option value="Dismissed">Dismissed / False Alarm</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn-submit" id="submitBtn">Update Control Mandate</button>
                </div>
            </form>
            <div class="modal-msg" id="modalMsg"></div>
        </div>
    </div>

    <script>
        // ─────────────────────────────────────────────
        //  DATA LAYER  (replace with real fetch calls)
        // ─────────────────────────────────────────────
        // In production, swap `MOCK_*` with actual API calls:
        //   const data = await fetch('/admin/api/reports').then(r=>r.json())

        const user = <%- JSON.stringify(user) %>;
        const reports = <%- JSON.stringify(reports) %>;
        const analytics = <%- JSON.stringify(analytics) %>;
        // ─────────────────────────────────────────────
        //  INIT
        // ─────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', () => {

            // Header
            document.getElementById('userName').textContent = user.name;

            // KPIs
            document.getElementById('kpiTotal').textContent = reports.length;
            const unique = [...new Set(reports.map(r => r.userId ? r.userId.phone : 'anon'))].length;
            document.getElementById('kpiReporters').textContent = unique;
            document.getElementById('kpiLastSync').textContent = 'Last sync: ' + new Date().toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });

            // ── Line Chart ──
            const signalsCtx = document.getElementById('signalsChart').getContext('2d');
            new Chart(signalsCtx, {
                type: 'line',
                data: {
                    labels: analytics.dailyCounts.labels,
                    datasets: [{
                        label: 'Signals Intercepted',
                        data: analytics.dailyCounts.data,
                        borderColor: '#FF9933',
                        backgroundColor: (ctx) => {
                            const g = ctx.chart.ctx.createLinearGradient(0, 0, 0, ctx.chart.height);
                            g.addColorStop(0, 'rgba(255,153,51,0.22)');
                            g.addColorStop(1, 'rgba(255,153,51,0)');
                            return g;
                        },
                        borderWidth: 3,
                        pointBackgroundColor: '#FF9933',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 6,
                        pointHoverRadius: 8,
                        tension: 0.45,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#0f172a',
                            titleFont: { family: 'DM Sans', size: 10, weight: '900' },
                            bodyFont: { family: 'DM Sans', size: 12, weight: '700' },
                            padding: 12,
                            cornerRadius: 0,
                            titleColor: '#94a3b8',
                            bodyColor: '#FF9933',
                            displayColors: false,
                            callbacks: {
                                title: (items) => items[0].label.toUpperCase(),
                                label: (item) => `  ${item.parsed.y} Signals`
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#f1f5f9', drawBorder: false },
                            ticks: {
                                font: { family: 'DM Sans', weight: '700', size: 11 },
                                color: '#94a3b8',
                                stepSize: 2
                            },
                            border: { display: false }
                        },
                        x: {
                            grid: { display: false, drawBorder: false },
                            ticks: {
                                font: { family: 'DM Sans', weight: '700', size: 11 },
                                color: '#94a3b8'
                            },
                            border: { display: false }
                        }
                    }
                }
            });

            // ── Donut Chart ──
            const statusCtx = document.getElementById('statusChart').getContext('2d');
            new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: Object.keys(analytics.statusCounts),
                    datasets: [{
                        data: Object.values(analytics.statusCounts),
                        backgroundColor: ['#94a3b8', '#2563eb', '#138808', '#dc2626'],
                        borderWidth: 4,
                        borderColor: '#ffffff',
                        hoverOffset: 14
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                pointStyle: 'rectRounded',
                                font: { family: 'DM Sans', size: 10, weight: '900' },
                                color: '#475569',
                                padding: 18
                            }
                        },
                        tooltip: {
                            backgroundColor: '#0f172a',
                            titleFont: { family: 'DM Sans', size: 10, weight: '900' },
                            bodyFont: { family: 'DM Sans', size: 11, weight: '700' },
                            cornerRadius: 0,
                            padding: 10,
                            displayColors: false
                        }
                    },
                    cutout: '68%'
                }
            });

            // ── Table ──
            function renderTable(reports) {
                const tbody = document.getElementById('reportsTbody');
                tbody.innerHTML = '';

                if (!reports.length) {
                    tbody.innerHTML = `<tr><td colspan="5" style="text-align:center;padding:2rem;color:var(--muted);font-size:0.8rem;">No signals recorded</td></tr>`;
                } else {
                    reports.forEach(report => {
                        const shortId = '#' + report._id.substring(18).toUpperCase();
                        const statusClass = (report.status || 'pending').toLowerCase().replace(/\s+/g, '');
                        const statusLabel = report.status || 'Pending';
                        const sourceHtml = report.userId
                            ? `<span class="source-name">${escHtml(report.userId.name)}</span>
           <span class="source-phone">${escHtml(report.userId.phone)}</span>`
                            : `<span class="anon-tag">Anonymous</span>`;

                        const tr = document.createElement('tr');
                        tr.className = 'report-row';
                        tr.dataset.report = JSON.stringify(report);
                        tr.innerHTML = `
        <td class="td-id">${shortId}</td>
        <td>${sourceHtml}</td>
        <td><div class="snippet" title="${escHtml(report.issue)}">${escHtml(report.issue)}</div></td>
        <td><span class="status-pill ${statusClass}">${statusLabel}</span></td>
        <td><button class="eye-btn" title="Intervene"><i class="fa-solid fa-eye"></i></button></td>
      `;
                        tr.addEventListener('click', () => openModal(report));
                        tbody.appendChild(tr);
                    });
                }
            }

            // ── Modal Logic ──
            const modal = document.getElementById('interventionModal');
            const modalClose = document.getElementById('modalCloseBtn');
            const modalBackdrop = document.getElementById('modalBackdrop');
            const statusForm = document.getElementById('statusForm');
            const modalMsg = document.getElementById('modalMsg');
            const submitBtn = document.getElementById('submitBtn');

            const openModal = (report) => {
                document.getElementById('modalIdDisplay').textContent = '#' + report._id.substring(18).toUpperCase();
                document.getElementById('modalSource').textContent = report.userId
                    ? `${report.userId.name}  ·  ${report.userId.phone}`
                    : 'ANONYMOUS SOURCE';
                document.getElementById('modalIssue').textContent = report.issue;
                document.getElementById('modalReportId').value = report._id;
                document.getElementById('modalStatus').value = report.status || 'Pending';
                modalMsg.textContent = '';
                modalMsg.className = 'modal-msg';
                modal.classList.add('open');
                document.body.style.overflow = 'hidden';
            };

            const closeModal = () => {
                modal.classList.remove('open');
                document.body.style.overflow = '';
            };

            renderTable(reports);

            modalClose.addEventListener('click', closeModal);
            modalBackdrop.addEventListener('click', closeModal);

            document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

            statusForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const reportId = document.getElementById('modalReportId').value;
                const status = document.getElementById('modalStatus').value;
                const origText = submitBtn.textContent;

                try {
                    submitBtn.disabled = true;
                    submitBtn.textContent = 'Executing…';

                    const res = await fetch(`/admin/report/${reportId}/status`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ status })
                    });

                    if (res.ok) {
                        modalMsg.className = 'modal-msg success';
                        modalMsg.textContent = 'Mandate Updated Successfully';
                        setTimeout(() => window.location.reload(), 1200);
                    } else {
                        modalMsg.className = 'modal-msg error';
                        modalMsg.textContent = 'Transition Failed — Check Logs';
                    }
                } catch (err) {
                    modalMsg.className = 'modal-msg error';
                    modalMsg.textContent = 'Connection Severed';
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.textContent = origText;
                }
            });
        });

        function escHtml(str) {
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }
    </script>
</body>

</html>
